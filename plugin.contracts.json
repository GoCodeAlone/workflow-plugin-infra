      "type": "infra.http_redirect",
      "mode": "strict",
      "config": "workflow.plugins.infra.v1.HTTPRedirectConfig"
    },
    {
      "kind": "module",
      "type": "infra.admin",
      "mode": "strict",
      "config": "workflow.plugins.infra.admin.v1.InfraAdminConfig"
